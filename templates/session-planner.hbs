<form class="dmj-planner" data-form="planner">
  <header class="dmj-planner-header">
    <div class="dmj-planner-title">
      <label for="dmj-session-title-{{formIdSuffix}}">{{localize "DMJ.Planner.SessionName"}}</label>
      <input id="dmj-session-title-{{formIdSuffix}}" name="name" type="text" value="{{name}}" maxlength="120" required>
    </div>
    <div class="dmj-planner-tools">
      <button type="button" class="dmj-open-board" data-action="open-board"><i class="fa-solid fa-route" aria-hidden="true"></i><span>{{localize "DMJ.Board.Open"}}</span></button>
      <button type="button" class="dmj-open-library" data-action="open-library"><i class="fa-solid fa-book-open" aria-hidden="true"></i><span>{{localize "DMJ.Resource.Library"}}</span></button>
    </div>
    <div class="dmj-planner-meta">
      <label>{{localize "DMJ.Planner.Date"}}<input name="date" type="date" value="{{date}}"></label>
      <label>{{localize "DMJ.Planner.Status"}}
        <select name="status">
          <option value="draft" {{#if statusDraft}}selected{{/if}}>{{localize "DMJ.Status.Draft"}}</option>
          <option value="ready" {{#if statusReady}}selected{{/if}}>{{localize "DMJ.Status.Ready"}}</option>
          <option value="played" {{#if statusPlayed}}selected{{/if}}>{{localize "DMJ.Status.Played"}}</option>
        </select>
      </label>
    </div>
  </header>

  <div class="dmj-planner-grid">
    <section class="dmj-planner-card wide accent">
      <label for="dmj-goal-{{formIdSuffix}}"><i class="fa-solid fa-bullseye" aria-hidden="true"></i> {{localize "DMJ.Field.goal"}}</label>
      <textarea id="dmj-goal-{{formIdSuffix}}" name="goal" rows="3" placeholder="{{localize "DMJ.Placeholder.goal"}}">{{goal}}</textarea>
    </section>
    <section class="dmj-planner-card">
      <label for="dmj-recap-{{formIdSuffix}}"><i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i> {{localize "DMJ.Field.recap"}}</label>
      <textarea id="dmj-recap-{{formIdSuffix}}" name="recap" rows="5">{{recap}}</textarea>
    </section>
    <section class="dmj-planner-card">
      <label for="dmj-opening-{{formIdSuffix}}"><i class="fa-solid fa-door-open" aria-hidden="true"></i> {{localize "DMJ.Field.opening"}}</label>
      <textarea id="dmj-opening-{{formIdSuffix}}" name="opening" rows="5">{{opening}}</textarea>
    </section>
    <section class="dmj-planner-card wide">
      <label for="dmj-scenes-{{formIdSuffix}}"><i class="fa-solid fa-clapperboard" aria-hidden="true"></i> {{localize "DMJ.Field.scenes"}}</label>
      <textarea id="dmj-scenes-{{formIdSuffix}}" name="scenes" rows="7" placeholder="{{localize "DMJ.Placeholder.scenes"}}">{{scenes}}</textarea>
    </section>
    <section class="dmj-planner-card">
      <label for="dmj-npcs-{{formIdSuffix}}"><i class="fa-solid fa-users" aria-hidden="true"></i> {{localize "DMJ.Field.npcs"}}</label>
      <textarea id="dmj-npcs-{{formIdSuffix}}" name="npcs" rows="6">{{npcs}}</textarea>
    </section>
    <section class="dmj-planner-card">
      <label for="dmj-locations-{{formIdSuffix}}"><i class="fa-solid fa-map-location-dot" aria-hidden="true"></i> {{localize "DMJ.Field.locations"}}</label>
      <textarea id="dmj-locations-{{formIdSuffix}}" name="locations" rows="6">{{locations}}</textarea>
    </section>
    <section class="dmj-planner-card">
      <label for="dmj-encounters-{{formIdSuffix}}"><i class="fa-solid fa-skull" aria-hidden="true"></i> {{localize "DMJ.Field.encounters"}}</label>
      <textarea id="dmj-encounters-{{formIdSuffix}}" name="encounters" rows="6">{{encounters}}</textarea>
    </section>
    <section class="dmj-planner-card">
      <label for="dmj-items-{{formIdSuffix}}"><i class="fa-solid fa-gem" aria-hidden="true"></i> {{localize "DMJ.Field.items"}}</label>
      <textarea id="dmj-items-{{formIdSuffix}}" name="items" rows="6">{{items}}</textarea>
    </section>
    <section class="dmj-planner-card">
      <label for="dmj-clues-{{formIdSuffix}}"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i> {{localize "DMJ.Field.clues"}}</label>
      <textarea id="dmj-clues-{{formIdSuffix}}" name="clues" rows="6">{{clues}}</textarea>
    </section>
    <section class="dmj-planner-card">
      <label for="dmj-improvisation-{{formIdSuffix}}"><i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i> {{localize "DMJ.Field.improvisation"}}</label>
      <textarea id="dmj-improvisation-{{formIdSuffix}}" name="improvisation" rows="6">{{improvisation}}</textarea>
    </section>
    <section class="dmj-planner-card wide">
      <label for="dmj-notes-{{formIdSuffix}}"><i class="fa-solid fa-pen-to-square" aria-hidden="true"></i> {{localize "DMJ.Field.notes"}}</label>
      <textarea id="dmj-notes-{{formIdSuffix}}" name="notes" rows="6">{{notes}}</textarea>
    </section>
  </div>

  <footer class="dmj-planner-actions">
    <span><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> {{localize "DMJ.Planner.Private"}}</span>
    <button type="submit"><i class="fa-solid fa-floppy-disk" aria-hidden="true"></i> {{localize "DMJ.Planner.Save"}}</button>
  </footer>
</form>
