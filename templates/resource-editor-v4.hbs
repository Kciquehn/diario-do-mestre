<form class="dmj-resource-form" data-form="resource-editor" data-resource-kind="{{kind}}">
  <header class="dmj-resource-header">
    <div class="dmj-resource-portrait">
      <button type="button" data-action="view-image" data-target="image" data-type="image" aria-label="{{localize "DMJ.Resource.OpenImage"}}" title="{{localize "DMJ.Resource.OpenImageHint"}}">
        <img src="{{preview}}" data-fallback="{{fallbackPreview}}" alt="" style="--dmj-image-position-x: {{imagePositionX}}%; --dmj-image-position-y: {{imagePositionY}}%; --dmj-image-zoom: {{imageZoomScale}};">
      </button>
    </div>
    <div class="dmj-resource-identity">
      <span>{{kindLabel}}</span>
      <input name="name" type="text" value="{{name}}" maxlength="120" required aria-label="{{localize "DMJ.Resource.Name"}}">
      <input name="image" type="hidden" value="{{image}}">
    </div>
    <div class="dmj-resource-image-controls" data-image-framing-controls hidden>
      <div class="dmj-resource-image-controls-heading">
        <strong><i class="fa-solid fa-crop-simple" aria-hidden="true"></i> {{localize "DMJ.Resource.AdjustImage"}}</strong>
        <button type="button" data-action="close-image-framing" aria-label="{{localize "DMJ.Resource.CloseImageAdjustment"}}" title="{{localize "DMJ.Resource.CloseImageAdjustment"}}"><i class="fa-solid fa-xmark" aria-hidden="true"></i></button>
      </div>
      <label>{{localize "DMJ.Resource.ImagePositionX"}} <input name="imagePositionX" type="range" min="0" max="100" step="1" value="{{imagePositionX}}" data-image-framing-input><output data-image-framing-output="imagePositionX">{{imagePositionX}}%</output></label>
      <label>{{localize "DMJ.Resource.ImagePositionY"}} <input name="imagePositionY" type="range" min="0" max="100" step="1" value="{{imagePositionY}}" data-image-framing-input><output data-image-framing-output="imagePositionY">{{imagePositionY}}%</output></label>
      <label>{{localize "DMJ.Resource.ImageZoom"}} <input name="imageZoom" type="range" min="100" max="300" step="5" value="{{imageZoom}}" data-image-framing-input><output data-image-framing-output="imageZoom">{{imageZoom}}%</output></label>
      <button type="button" class="dmj-resource-image-reset" data-action="reset-image-framing"><i class="fa-solid fa-rotate-left" aria-hidden="true"></i> {{localize "DMJ.Resource.ResetImageAdjustment"}}</button>
    </div>
  </header>
  <section class="dmj-resource-link">
    <input name="linkedUuid" type="hidden" value="{{linkedUuid}}">
    <i class="fa-solid fa-link" aria-hidden="true"></i>
    <div><strong>{{localize "DMJ.Resource.Linked"}}</strong><button class="dmj-resource-linked-name" type="button" data-action="open-linked" data-linked-name aria-label="{{localize "DMJ.Resource.OpenLinked"}}" {{#unless hasLinked}}disabled{{/unless}}>{{#if hasLinked}}{{linkedName}} ({{linkedType}}){{else}}{{localize "DMJ.Resource.Drop"}}{{/if}}</button></div>
  </section>
  <main class="dmj-resource-fields">
    <section class="dmj-city-map-panel wide" data-city-map>
        <header>
          <div><strong><i class="fa-solid fa-map-location-dot" aria-hidden="true"></i> {{localize "DMJ.CityMap.Title"}}</strong><small>{{localize "DMJ.CityMap.Help"}}</small></div>
          <div class="dmj-city-map-actions">
            <span data-city-map-zoom>{{cityMapZoomLabel}}</span>
            <button type="button" data-action="select-city-map" data-target="cityMapImage" data-type="image"><i class="fa-solid fa-image" aria-hidden="true"></i> <span data-city-map-image-action-label>{{#if cityMap.image}}{{localize "DMJ.CityMap.ChangeImage"}}{{else}}{{localize "DMJ.CityMap.SelectImage"}}{{/if}}</span></button>
            <button type="button" data-action="add-city-location"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {{localize "DMJ.CityMap.AddLocation"}}</button>
            <button type="button" data-action="reset-city-map-view" aria-label="{{localize "DMJ.CityMap.ResetView"}}" title="{{localize "DMJ.CityMap.ResetView"}}"><i class="fa-solid fa-crosshairs" aria-hidden="true"></i></button>
          </div>
        </header>
        <input name="cityMapImage" type="hidden" value="{{cityMap.image}}">
        <textarea name="cityMap" hidden>{{cityMapJSON}}</textarea>
        <div class="dmj-city-map-viewport" data-city-map-viewport tabindex="0" role="application" aria-label="{{localize "DMJ.CityMap.ViewportLabel"}}">
          <div class="dmj-city-map-stage" data-city-map-stage style="transform: translate({{cityMap.panX}}px, {{cityMap.panY}}px) scale({{cityMap.zoom}});">
            <div class="dmj-city-map-background" data-city-map-background></div>
            <div class="dmj-city-map-locations" data-city-map-locations></div>
          </div>
        </div>
    </section>
    {{#each fields}}<label>{{label}}<div class="dmj-resource-rich-editor" contenteditable="true" role="textbox" aria-multiline="true" aria-keyshortcuts="Control+B Control+I" data-resource-rich-editor data-field-name="{{id}}" data-placeholder="{{localize "DMJ.Resource.EditorPlaceholder"}}" aria-label="{{label}}">{{{editorHTML}}}</div><textarea class="dmj-resource-field-value" name="{{id}}" hidden>{{editorHTML}}</textarea></label>{{/each}}
    <label class="wide">{{localize "DMJ.Resource.Notes"}}<div class="dmj-resource-rich-editor dmj-resource-rich-editor-notes" contenteditable="true" role="textbox" aria-multiline="true" aria-keyshortcuts="Control+B Control+I" data-resource-rich-editor data-field-name="notes" data-placeholder="{{localize "DMJ.Resource.EditorPlaceholder"}}" aria-label="{{localize "DMJ.Resource.Notes"}}">{{{notesHTML}}}</div><textarea class="dmj-resource-field-value" name="notes" hidden>{{notesHTML}}</textarea></label>
  </main>
  <footer class="dmj-resource-actions"><span><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> {{localize "DMJ.Planner.Private"}}</span><span class="dmj-autosave-status" data-resource-autosave-status data-state="saved" role="status" aria-live="polite"><i class="fa-solid fa-check" aria-hidden="true"></i><span>{{localize "DMJ.Resource.AutosaveSaved"}}</span></span></footer>
</form>
