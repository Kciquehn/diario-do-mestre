<form class="dmj-resource-form" data-form="resource-editor" data-resource-kind="{{kind}}"{{#if isPlace}} data-place-type="{{placeType}}" data-place-layout="{{layout}}" data-header-collapsed="{{headerCollapsed}}"{{/if}}>
  <header class="dmj-resource-header{{#if isCity}} dmj-resource-header-city{{/if}}{{#if isPlace}} dmj-resource-header-place{{/if}}{{#if isPerson}} dmj-resource-header-person{{/if}}{{#unless isCity}}{{#unless isPlace}} dmj-resource-header-linked{{/unless}}{{/unless}}">
    {{#if isPlace}}
      <input name="headerCollapsed" type="hidden" value="{{headerCollapsed}}">
      <button type="button" class="dmj-resource-header-toggle" data-action="toggle-place-header" aria-expanded="{{#if headerCollapsed}}false{{else}}true{{/if}}" aria-label="{{#if headerCollapsed}}{{localize "DMJ.Resource.ShowHeader"}}{{else}}{{localize "DMJ.Resource.HideHeader"}}{{/if}}" title="{{#if headerCollapsed}}{{localize "DMJ.Resource.ShowHeader"}}{{else}}{{localize "DMJ.Resource.HideHeader"}}{{/if}}"><i class="fa-solid {{#if headerCollapsed}}fa-chevron-down{{else}}fa-chevron-up{{/if}}" aria-hidden="true"></i></button>
    {{/if}}
    {{#unless isCity}}
      <div class="dmj-resource-portrait">
        <button type="button" data-action="view-image" data-target="image" data-type="image" aria-label="{{localize "DMJ.Resource.OpenImage"}}" title="{{localize "DMJ.Resource.OpenImageHint"}}">
          <img src="{{preview}}" data-fallback="{{fallbackPreview}}" alt="" style="--dmj-image-position-x: {{imagePositionX}}%; --dmj-image-position-y: {{imagePositionY}}%; --dmj-image-zoom: {{imageZoomScale}};">
        </button>
      </div>
    {{/unless}}
    <div class="dmj-resource-identity">
      <span>{{kindLabel}}</span>
      <input name="name" type="text" value="{{name}}" maxlength="120" required aria-label="{{localize "DMJ.Resource.Name"}}">
      {{#if isPlace}}
        <div class="dmj-place-settings">
          <label class="dmj-place-type-control"><span>{{localize "DMJ.Resource.PlaceType.Label"}}</span><select name="placeType">{{#each placeTypes}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
          <fieldset class="dmj-place-layout-picker">
            <legend>{{localize "DMJ.Resource.Layout.Label"}}</legend>
            {{#each placeLayouts}}<label title="{{hint}}"><input type="radio" name="layout" value="{{id}}" {{#if selected}}checked{{/if}}><span><i class="fa-solid {{icon}}" aria-hidden="true"></i><b>{{label}}</b></span></label>{{/each}}
          </fieldset>
          {{#if itemPilesActive}}
            <section class="dmj-commerce-settings">
              <div class="dmj-commerce-settings-title"><i class="fa-solid fa-store" aria-hidden="true"></i><strong>{{localize "DMJ.ItemPiles.Commerce"}}</strong>{{#if itemPilesProviderLabel}}<small>{{itemPilesProviderLabel}}</small>{{/if}}</div>
              {{#if itemPilesConflict}}<p class="dmj-commerce-integration-warning">{{localize "DMJ.ItemPiles.Error.Conflict"}}</p>{{/if}}
              <label><span>{{localize "DMJ.ItemPiles.Merchant"}}</span><select name="commerceMerchantUuid"><option value="">{{localize "DMJ.ItemPiles.NoMerchant"}}</option>{{#each merchantOptions}}<option value="{{uuid}}" {{#if selected}}selected{{/if}}>{{name}}</option>{{/each}}</select></label>
              <div class="dmj-commerce-actions">
                <button type="button" data-action="open-commerce" {{#unless hasCommerceMerchant}}disabled{{/unless}}><i class="fa-solid fa-door-open" aria-hidden="true"></i> {{localize "DMJ.ItemPiles.OpenMerchant"}}</button>
              </div>
            </section>
          {{/if}}
        </div>
      {{/if}}
      <input name="image" type="hidden" value="{{image}}">
    </div>
    {{#unless isCity}}
      {{#unless isPlace}}
        <section class="dmj-resource-link dmj-resource-link-header{{#if hasLinked}} has-linked{{/if}}" title="{{linkedLabel}}">
          {{#if isPerson}}<small>{{localize "DMJ.Resource.Linked"}}</small>{{/if}}
          <input name="linkedUuid" type="hidden" value="{{linkedUuid}}">
          <button class="dmj-resource-linked-name" type="button" data-action="open-linked" aria-label="{{#if hasLinked}}{{localize "DMJ.Resource.OpenLinked"}}: {{linkedLabel}}{{else}}{{localize "DMJ.Resource.Drop"}}{{/if}}" title="{{linkedLabel}}" {{#unless hasLinked}}disabled{{/unless}}><i class="fa-solid fa-link" aria-hidden="true"></i><span class="dmj-resource-linked-label" data-linked-name>{{linkedLabel}}</span></button>
        </section>
      {{/unless}}
    {{/unless}}
    {{#unless isCity}}
      <div class="dmj-resource-image-controls" data-image-framing-controls hidden>
        <div class="dmj-resource-image-controls-heading">
          <strong><i class="fa-solid fa-crop-simple" aria-hidden="true"></i> {{localize "DMJ.Resource.AdjustImage"}}</strong>
          <button type="button" data-action="close-image-framing" aria-label="{{localize "DMJ.Resource.CloseImageAdjustment"}}" title="{{localize "DMJ.Resource.CloseImageAdjustment"}}"><i class="fa-solid fa-xmark" aria-hidden="true"></i></button>
        </div>
        <label>{{localize "DMJ.Resource.ImagePositionX"}} <input name="imagePositionX" type="range" min="0" max="100" step="1" value="{{imagePositionX}}" data-image-framing-input><output data-image-framing-output="imagePositionX">{{imagePositionX}}%</output></label>
        <label>{{localize "DMJ.Resource.ImagePositionY"}} <input name="imagePositionY" type="range" min="0" max="100" step="1" value="{{imagePositionY}}" data-image-framing-input><output data-image-framing-output="imagePositionY">{{imagePositionY}}%</output></label>
        <label>{{localize "DMJ.Resource.ImageZoom"}} <input name="imageZoom" type="range" min="100" max="300" step="5" value="{{imageZoom}}" data-image-framing-input><output data-image-framing-output="imageZoom">{{imageZoom}}%</output></label>
        <button type="button" class="dmj-resource-image-reset" data-action="reset-image-framing"><i class="fa-solid fa-rotate-left" aria-hidden="true"></i> {{localize "DMJ.Resource.ResetImageAdjustment"}}</button>
      </div>
    {{/unless}}
  </header>
  <section class="dmj-player-publication-settings{{#if isPerson}} dmj-person-publication-settings{{/if}}">
    <div><i class="fa-solid fa-users-viewfinder" aria-hidden="true"></i><span><strong>{{localize "DMJ.PlayerDiary.Publish.Title"}}</strong><small>{{localize "DMJ.PlayerDiary.Publish.Hint"}}</small></span></div>
    <label><input type="checkbox" name="publicationPublished" value="true" {{#if publicationPublished}}checked{{/if}}><span>{{localize "DMJ.PlayerDiary.Publish.Toggle"}}</span></label>
  </section>
  {{#if isPerson}}
    <main class="dmj-person-accordion">
      {{#each fields}}
        <details class="dmj-person-section" {{#if expanded}}open{{/if}}>
          <summary><span><i class="fa-solid {{icon}}" aria-hidden="true"></i>{{label}}</span><i class="fa-solid fa-chevron-down dmj-person-section-chevron" aria-hidden="true"></i></summary>
          <div class="dmj-person-section-content">
            <div class="dmj-resource-rich-editor" contenteditable="true" role="textbox" aria-multiline="true" aria-keyshortcuts="Control+B Control+I" data-resource-rich-editor data-field-name="{{id}}" data-placeholder="{{localize "DMJ.Resource.EditorPlaceholder"}}" aria-label="{{label}}">{{{editorHTML}}}</div>
            <textarea class="dmj-resource-field-value" name="{{id}}" hidden>{{editorHTML}}</textarea>
          </div>
        </details>
      {{/each}}
      <details class="dmj-person-section dmj-person-section-notes">
        <summary><span><i class="fa-solid fa-note-sticky" aria-hidden="true"></i>{{localize "DMJ.Resource.Notes"}}</span><i class="fa-solid fa-chevron-down dmj-person-section-chevron" aria-hidden="true"></i></summary>
        <div class="dmj-person-section-content">
          <div class="dmj-resource-rich-editor dmj-resource-rich-editor-notes" contenteditable="true" role="textbox" aria-multiline="true" aria-keyshortcuts="Control+B Control+I" data-resource-rich-editor data-field-name="notes" data-placeholder="{{localize "DMJ.Resource.EditorPlaceholder"}}" aria-label="{{localize "DMJ.Resource.Notes"}}">{{{notesHTML}}}</div>
          <textarea class="dmj-resource-field-value" name="notes" hidden>{{notesHTML}}</textarea>
        </div>
      </details>
    </main>
  {{else}}
    <main class="dmj-resource-fields">
      {{#each fields}}<label>{{label}}<div class="dmj-resource-rich-editor" contenteditable="true" role="textbox" aria-multiline="true" aria-keyshortcuts="Control+B Control+I" data-resource-rich-editor data-field-name="{{id}}" data-placeholder="{{localize "DMJ.Resource.EditorPlaceholder"}}" aria-label="{{label}}">{{{editorHTML}}}</div><textarea class="dmj-resource-field-value" name="{{id}}" hidden>{{editorHTML}}</textarea></label>{{/each}}
      <label class="wide">{{localize "DMJ.Resource.Notes"}}<div class="dmj-resource-rich-editor dmj-resource-rich-editor-notes" contenteditable="true" role="textbox" aria-multiline="true" aria-keyshortcuts="Control+B Control+I" data-resource-rich-editor data-field-name="notes" data-placeholder="{{localize "DMJ.Resource.EditorPlaceholder"}}" aria-label="{{localize "DMJ.Resource.Notes"}}">{{{notesHTML}}}</div><textarea class="dmj-resource-field-value" name="notes" hidden>{{notesHTML}}</textarea></label>
    </main>
  {{/if}}
  <footer class="dmj-resource-actions"><span><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> {{localize "DMJ.Planner.Private"}}</span><span class="dmj-autosave-status" data-resource-autosave-status data-state="saved" role="status" aria-live="polite"><i class="fa-solid fa-check" aria-hidden="true"></i><span>{{localize "DMJ.Resource.AutosaveSaved"}}</span></span></footer>
</form>
